(kicad_pcb
  (version 20221018)
  (generator "hand_coded")
  (general
    (thickness 1.0)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "DaPao Space Mouse — Upper PCB")
    (date "2026-03-19")
    (rev "1.1")
    (comment 1 "Circular ∅54mm, 2-layer, 1.0mm thick")
    (comment 2 "Button board: L/R click + FWD/BACK + FPC connector")
    (comment 3 "Rev 1.1: Switch + mount positions aligned to case top_frame v3")
  )

  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
  )

  (setup
    (pad_to_mask_clearance 0.05)
    (aux_axis_origin 0 0)
    (grid_origin 0 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
    )
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "3V3")
  (net 3 "BTN_LEFT")
  (net 4 "BTN_RIGHT")
  (net 5 "BTN_BACK")
  (net 6 "BTN_FWD")

  ;; ============================================================
  ;; BOARD OUTLINE — Circular ∅54mm, centered at (100,100)
  ;; ============================================================

  (gr_circle (center 100 100) (end 127 100)
    (stroke (width 0.1) (type solid))
    (layer "Edge.Cuts")
    (uuid "40000001-0001-0001-0001-000000000001")
  )

  ;; ============================================================
  ;; COORDINATE SYSTEM
  ;; Board center = (100,100) in KiCad coords.
  ;; Case params (mm from center):
  ;;   SW4 L-Click:  X=-10, Y=-12 (KiCad Y is inverted → KiCad: 90, 88)
  ;;   SW5 R-Click:  X=+10, Y=-12 (KiCad: 110, 88)
  ;;   SW6 Back:     X=-24, Y=0   (KiCad: 76, 100)  ← board left edge
  ;;   SW7 Forward:  X=+24, Y=0   (KiCad: 124, 100) ← board right edge
  ;;   H1 Mount:     X=-15, Y=0   (KiCad: 85, 100)
  ;;   H2 Mount:     X=+15, Y=0   (KiCad: 115, 100)
  ;; ============================================================

  ;; ============================================================
  ;; MOUNTING HOLES — 2× M2, at X=±15mm from center (Y=0)
  ;; Matches top_frame case posts: top_mount_x=15, top_mount_y=0
  ;; ============================================================

  (footprint "MountingHole:MountingHole_2.2mm_M2_Pad"
    (layer "F.Cu")
    (uuid "50000001-0001-0001-0001-000000000001")
    (at 85 100)
    (property "Reference" "H1" (at 0 -3 0) (layer "F.SilkS") (uuid "50000001-0001-0001-0001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_M2" (at 0 3 0) (layer "F.Fab") (uuid "50000001-0001-0001-0001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask") (net 0 ""))
  )

  (footprint "MountingHole:MountingHole_2.2mm_M2_Pad"
    (layer "F.Cu")
    (uuid "50000001-0001-0001-0001-000000000002")
    (at 115 100)
    (property "Reference" "H2" (at 0 -3 0) (layer "F.SilkS") (uuid "50000001-0001-0001-0001-200000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_M2" (at 0 3 0) (layer "F.Fab") (uuid "50000001-0001-0001-0001-200000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask") (net 0 ""))
  )

  ;; ============================================================
  ;; SW4 — Left Click (Kailh micro switch)
  ;; Position: X=-10mm, Y=-12mm from center → KiCad (90, 88)
  ;; Plunger faces UP (+Z), pressed by left half-circle button
  ;; Matches case top_frame: top_sw_x=10, top_sw_offset_y=12
  ;; ============================================================

  (footprint "Button_Switch_SMD:SW_Push_1P1T_NO_6x6mm_H9.5mm"
    (layer "F.Cu")
    (uuid "70000001-0001-0001-0001-000000000001")
    (at 90 88)
    (property "Reference" "SW4" (at 0 -5 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "SW_L-Click" (at 0 5 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole rect (at -2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 3 "BTN_LEFT"))
    (pad "2" thru_hole circle (at 2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 1 "GND"))
  )

  ;; ============================================================
  ;; SW5 — Right Click (Kailh micro switch)
  ;; Position: X=+10mm, Y=-12mm from center → KiCad (110, 88)
  ;; Plunger faces UP (+Z), pressed by right half-circle button
  ;; Matches case top_frame: top_sw_x=10, top_sw_offset_y=12
  ;; ============================================================

  (footprint "Button_Switch_SMD:SW_Push_1P1T_NO_6x6mm_H9.5mm"
    (layer "F.Cu")
    (uuid "70000001-0001-0001-0001-000000000002")
    (at 110 88)
    (property "Reference" "SW5" (at 0 -5 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-200000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "SW_R-Click" (at 0 5 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-200000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole rect (at -2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 4 "BTN_RIGHT"))
    (pad "2" thru_hole circle (at 2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 1 "GND"))
  )

  ;; ============================================================
  ;; SW6 — Back button (side-mount tactile, at left board edge)
  ;; Position: X=-24mm (board edge), Y=0 → KiCad (76, 100)
  ;; Plunger faces LEFT (outward through top_frame side cutout)
  ;; Side button cap on body shell presses inward to activate
  ;; ============================================================

  (footprint "Button_Switch_THT:SW_Push_1P1T_NO_6x6mm_H9.5mm"
    (layer "F.Cu")
    (uuid "70000001-0001-0001-0001-000000000003")
    (at 76 100 90)
    (property "Reference" "SW6" (at 0 -5 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-300000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "SW_Back" (at 0 5 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-300000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole rect (at -2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 5 "BTN_BACK"))
    (pad "2" thru_hole circle (at 2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 1 "GND"))
  )

  ;; ============================================================
  ;; SW7 — Forward button (side-mount tactile, at right board edge)
  ;; Position: X=+24mm (board edge), Y=0 → KiCad (124, 100)
  ;; Plunger faces RIGHT (outward through top_frame side cutout)
  ;; ============================================================

  (footprint "Button_Switch_THT:SW_Push_1P1T_NO_6x6mm_H9.5mm"
    (layer "F.Cu")
    (uuid "70000001-0001-0001-0001-000000000004")
    (at 124 100 270)
    (property "Reference" "SW7" (at 0 -5 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-400000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "SW_Forward" (at 0 5 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-400000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole rect (at -2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 6 "BTN_FWD"))
    (pad "2" thru_hole circle (at 2.5 0) (size 1.5 1.5) (drill 0.8) (layers "*.Cu" "*.Mask") (net 1 "GND"))
  )

  ;; ============================================================
  ;; J5 — FPC 6-pin connector (bottom of board, routes to lower PCB)
  ;; ============================================================

  (gr_text "FPC J5\n(to lower PCB)"
    (at 100 117 0)
    (layer "F.SilkS")
    (uuid "60000001-0001-0001-0001-000000000005")
    (effects (font (size 1 1) (thickness 0.15)))
  )

  ;; ============================================================
  ;; SILKSCREEN LABELS
  ;; ============================================================

  (gr_text "FRONT\n(click side)"
    (at 100 77 0)
    (layer "F.SilkS")
    (uuid "60000001-0001-0001-0001-000000000006")
    (effects (font (size 1.2 1.2) (thickness 0.15)))
  )

  (gr_text "SW4 L-CLICK\n↑ X=-10 Y=+12"
    (at 90 83 0)
    (layer "F.SilkS")
    (uuid "60000001-0001-0001-0001-000000000007")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )

  (gr_text "SW5 R-CLICK\n↑ X=+10 Y=+12"
    (at 110 83 0)
    (layer "F.SilkS")
    (uuid "60000001-0001-0001-0001-000000000008")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )

  (gr_text "SW6\nBACK\n←"
    (at 73 100 0)
    (layer "F.SilkS")
    (uuid "60000001-0001-0001-0001-000000000009")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )

  (gr_text "SW7\nFWD\n→"
    (at 127 100 0)
    (layer "F.SilkS")
    (uuid "60000001-0001-0001-0001-000000000010")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )

  ;; ============================================================
  ;; ALIGNMENT NOTES (Rev 1.1)
  ;; ============================================================
  ;; All positions verified against case/parts/params.scad:
  ;;
  ;; SW4 (L-Click):  case top_sw_x=10, top_sw_offset_y=12  ✓
  ;; SW5 (R-Click):  case top_sw_x=10, top_sw_offset_y=12  ✓
  ;; SW6 (Back):     at board edge X=-24, top_frame cutout at ±inner_r ✓
  ;; SW7 (Forward):  at board edge X=+24, top_frame cutout at ±inner_r ✓
  ;; H1/H2 (Mount):  case top_mount_x=15, top_mount_y=0    ✓
  ;; PCB diameter:   ∅54mm = frame_id (60 - 2×3)           ✓

)
