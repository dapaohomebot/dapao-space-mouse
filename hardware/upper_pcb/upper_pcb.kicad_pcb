(kicad_pcb
  (version 20221018)
  (generator "hand_coded")
  (general
    (thickness 1.0)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "DaPao Space Mouse - Upper PCB")
    (date "2026-03-20")
    (rev "1.3")
    (comment 1 "Circular dia54mm, 2-layer, 1.0mm thick")
    (comment 2 "SW4/SW5: Kailh GM 8.0 (3-pin THT Cherry-style)")
    (comment 3 "SW6/SW7: Kailh Blue Dot SMT side-button")
    (comment 4 "Rev 1.3: upgraded from 6x6 tactile to micro switches")
  )

  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (44 "Edge.Cuts" user)
  )

  (setup
    (pad_to_mask_clearance 0.05)
    (aux_axis_origin 0 0)
    (grid_origin 0 0)
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "3V3")
  (net 3 "BTN_LEFT")
  (net 4 "BTN_RIGHT")
  (net 5 "BTN_BACK")
  (net 6 "BTN_FWD")

  ;; ============================================================
  ;; BOARD OUTLINE - Circular dia54mm centered at (100,100)
  ;; ============================================================
  (gr_circle (center 100 100) (end 127 100)
    (stroke (width 0.1) (type solid))
    (layer "Edge.Cuts")
    (uuid "40000001-0001-0001-0001-000000000001")
  )

  ;; ============================================================
  ;; COORDINATE SYSTEM
  ;; Board center = (100,100). Case params (mm from center):
  ;;   SW4 L-Click:  X=-10, Y=-12  ->  KiCad (90, 88)
  ;;   SW5 R-Click:  X=+10, Y=-12  ->  KiCad (110, 88)
  ;;   SW6 Back:     X=-24, Y=0    ->  KiCad (76, 100)
  ;;   SW7 Forward:  X=+24, Y=0    ->  KiCad (124, 100)
  ;;   H1 Mount:     X=-15, Y=0    ->  KiCad (85, 100)
  ;;   H2 Mount:     X=+15, Y=0    ->  KiCad (115, 100)
  ;; ============================================================

  ;; ============================================================
  ;; MOUNTING HOLES - 2x M2 at X=+-15mm (matches top_frame posts)
  ;; ============================================================
  (footprint "MountingHole:MountingHole_2.2mm_M2_Pad"
    (layer "F.Cu") (uuid "50000001-0001-0001-0001-000000000001") (at 85 100)
    (property "Reference" "H1" (at 0 -3 0) (layer "F.SilkS") (uuid "50000001-0001-0001-0001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_M2" (at 0 3 0) (layer "F.Fab") (uuid "50000001-0001-0001-0001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask") (net 0 ""))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2_Pad"
    (layer "F.Cu") (uuid "50000001-0001-0001-0001-000000000002") (at 115 100)
    (property "Reference" "H2" (at 0 -3 0) (layer "F.SilkS") (uuid "50000001-0001-0001-0001-200000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_M2" (at 0 3 0) (layer "F.Fab") (uuid "50000001-0001-0001-0001-200000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 4.4 4.4) (drill 2.2) (layers "*.Cu" "*.Mask") (net 0 ""))
  )

  ;; ============================================================
  ;; SW4 - Kailh GM 8.0 (Left Click)
  ;; Position: (90, 88) = X=-10, Y=-12 from center
  ;; 3-pin Cherry-style, 2.54mm pitch: COM | NO | NC
  ;; Footprint: SW_Push_SPDT_CherryMX (pin spacing 2.54mm)
  ;; Body: 12.8 x 5.8mm — long axis along X (left-right)
  ;; Plunger faces UP, pressed by left rocker button plunger nub
  ;; Wiring: COM->GND, NO->BTN_LEFT+R1, NC->not connected
  ;; ============================================================
  (footprint "Button_Switch_THT:SW_Push_SPDT_CherryMX_12.8x5.8mm"
    (layer "F.Cu") (uuid "70000001-0001-0001-0001-000000000001") (at 90 88)
    (property "Reference" "SW4" (at 0 -6 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "Kailh_GM_8.0" (at 0 6 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    ;; Pin layout (Cherry-style): 3 pins in a row, 2.54mm pitch
    ;; Pin 1 = COM (leftmost),  Pin 2 = NO (middle),  Pin 3 = NC (rightmost)
    (pad "1" thru_hole rect  (at -2.54 0) (size 2.0 2.0) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND"))
    (pad "2" thru_hole circle (at 0    0) (size 2.0 2.0) (drill 1.0) (layers "*.Cu" "*.Mask") (net 3 "BTN_LEFT"))
    (pad "3" thru_hole circle (at 2.54 0) (size 2.0 2.0) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
  )

  ;; ============================================================
  ;; SW5 - Kailh GM 8.0 (Right Click)
  ;; Position: (110, 88) = X=+10, Y=-12 from center
  ;; Same footprint as SW4, mirrored
  ;; Wiring: COM->GND, NO->BTN_RIGHT+R2, NC->not connected
  ;; ============================================================
  (footprint "Button_Switch_THT:SW_Push_SPDT_CherryMX_12.8x5.8mm"
    (layer "F.Cu") (uuid "70000001-0001-0001-0001-000000000002") (at 110 88)
    (property "Reference" "SW5" (at 0 -6 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-200000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "Kailh_GM_8.0" (at 0 6 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-200000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole rect  (at -2.54 0) (size 2.0 2.0) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND"))
    (pad "2" thru_hole circle (at 0    0) (size 2.0 2.0) (drill 1.0) (layers "*.Cu" "*.Mask") (net 4 "BTN_RIGHT"))
    (pad "3" thru_hole circle (at 2.54 0) (size 2.0 2.0) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
  )

  ;; ============================================================
  ;; SW6 - Kailh Blue Dot SMT Side Button (Back)
  ;; Position: (76, 100) = X=-24, Y=0 — left board edge
  ;; SMD, ~8.75mm body, plunger faces LEFT (outward)
  ;; Rotated 90deg: plunger points toward board edge
  ;; Wiring: Pin1->GND, Pin2->BTN_BACK+R3
  ;; ============================================================
  (footprint "Button_Switch_SMD:SW_Push_Side_8.75mm"
    (layer "F.Cu") (uuid "70000001-0001-0001-0001-000000000003") (at 76 100 90)
    (property "Reference" "SW6" (at 0 -6 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-300000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "Kailh_BlueDot_Side" (at 0 6 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-300000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" smd rect  (at -2.5 0) (size 1.5 2.0) (layers "F.Cu" "F.Mask") (net 1 "GND"))
    (pad "2" smd circle (at  2.5 0) (size 1.5 2.0) (layers "F.Cu" "F.Mask") (net 5 "BTN_BACK"))
  )

  ;; ============================================================
  ;; SW7 - Kailh Blue Dot SMT Side Button (Forward)
  ;; Position: (124, 100) = X=+24, Y=0 — right board edge
  ;; Plunger faces RIGHT (outward), rotated 270deg
  ;; Wiring: Pin1->GND, Pin2->BTN_FWD+R4
  ;; ============================================================
  (footprint "Button_Switch_SMD:SW_Push_Side_8.75mm"
    (layer "F.Cu") (uuid "70000001-0001-0001-0001-000000000004") (at 124 100 270)
    (property "Reference" "SW7" (at 0 -6 0) (layer "F.SilkS") (uuid "70000001-0001-0001-0001-400000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "Kailh_BlueDot_Side" (at 0 6 0) (layer "F.Fab") (uuid "70000001-0001-0001-0001-400000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" smd rect  (at -2.5 0) (size 1.5 2.0) (layers "F.Cu" "F.Mask") (net 1 "GND"))
    (pad "2" smd circle (at  2.5 0) (size 1.5 2.0) (layers "F.Cu" "F.Mask") (net 6 "BTN_FWD"))
  )

  ;; ============================================================
  ;; R1-R4 - 10k pull-up resistors (0402 SMD)
  ;; Placed between each switch signal and 3V3 rail
  ;; ============================================================
  (footprint "Resistor_SMD:R_0402_1005Metric"
    (layer "F.Cu") (uuid "80000001-0001-0001-0001-000000000001") (at 90 82)
    (property "Reference" "R1" (at 0 -2 0) (layer "F.SilkS") (uuid "80000001-0001-0001-0001-100000000001") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "10k" (at 0 2 0) (layer "F.Fab") (uuid "80000001-0001-0001-0001-100000000002") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (pad "1" smd rect  (at -0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 2 "3V3"))
    (pad "2" smd circle (at  0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 3 "BTN_LEFT"))
  )
  (footprint "Resistor_SMD:R_0402_1005Metric"
    (layer "F.Cu") (uuid "80000001-0001-0001-0001-000000000002") (at 110 82)
    (property "Reference" "R2" (at 0 -2 0) (layer "F.SilkS") (uuid "80000001-0001-0001-0001-200000000001") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "10k" (at 0 2 0) (layer "F.Fab") (uuid "80000001-0001-0001-0001-200000000002") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (pad "1" smd rect  (at -0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 2 "3V3"))
    (pad "2" smd circle (at  0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 4 "BTN_RIGHT"))
  )
  (footprint "Resistor_SMD:R_0402_1005Metric"
    (layer "F.Cu") (uuid "80000001-0001-0001-0001-000000000003") (at 82 100)
    (property "Reference" "R3" (at 0 -2 0) (layer "F.SilkS") (uuid "80000001-0001-0001-0001-300000000001") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "10k" (at 0 2 0) (layer "F.Fab") (uuid "80000001-0001-0001-0001-300000000002") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (pad "1" smd rect  (at -0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 2 "3V3"))
    (pad "2" smd circle (at  0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 5 "BTN_BACK"))
  )
  (footprint "Resistor_SMD:R_0402_1005Metric"
    (layer "F.Cu") (uuid "80000001-0001-0001-0001-000000000004") (at 118 100)
    (property "Reference" "R4" (at 0 -2 0) (layer "F.SilkS") (uuid "80000001-0001-0001-0001-400000000001") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "10k" (at 0 2 0) (layer "F.Fab") (uuid "80000001-0001-0001-0001-400000000002") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (pad "1" smd rect  (at -0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 2 "3V3"))
    (pad "2" smd circle (at  0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 6 "BTN_FWD"))
  )

  ;; ============================================================
  ;; C1 - 100nF decoupling (0402)
  ;; ============================================================
  (footprint "Capacitor_SMD:C_0402_1005Metric"
    (layer "F.Cu") (uuid "90000001-0001-0001-0001-000000000001") (at 104 114)
    (property "Reference" "C1" (at 0 -2 0) (layer "F.SilkS") (uuid "90000001-0001-0001-0001-100000000001") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "100nF" (at 0 2 0) (layer "F.Fab") (uuid "90000001-0001-0001-0001-100000000002") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (pad "1" smd rect  (at -0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 2 "3V3"))
    (pad "2" smd circle (at  0.56 0) (size 0.7 0.9) (layers "F.Cu" "F.Mask") (net 1 "GND"))
  )

  ;; ============================================================
  ;; J5 - FPC 6-pin 0.5mm top-contact connector
