  ;; ============================================================
  (footprint "Connector_FFC-FPC:Hirose_FH12-6S-0.5SH_1x06-1MP_P0.5mm_Horizontal"
    (layer "F.Cu") (uuid "60000001-0001-0001-0001-000000000001") (at 100 115)
    (property "Reference" "J5" (at 0 -5 0) (layer "F.SilkS") (uuid "60000001-0001-0001-0001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "FPC_6pin_0.5mm" (at 0 5 0) (layer "F.Fab") (uuid "60000001-0001-0001-0001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" smd rect  (at -1.25 0) (size 0.4 1.5) (layers "F.Cu" "F.Mask") (net 2 "3V3"))
    (pad "2" smd rect  (at -0.75 0) (size 0.4 1.5) (layers "F.Cu" "F.Mask") (net 1 "GND"))
    (pad "3" smd rect  (at -0.25 0) (size 0.4 1.5) (layers "F.Cu" "F.Mask") (net 3 "BTN_LEFT"))
    (pad "4" smd rect  (at  0.25 0) (size 0.4 1.5) (layers "F.Cu" "F.Mask") (net 4 "BTN_RIGHT"))
