  (gr_text "SW5\nGM8.0\nR-CLICK\nplunger UP" (at 110 80 0) (layer "F.SilkS") (uuid "a0000002") (effects (font (size 0.8 0.8) (thickness 0.12))))
  (gr_text "SW6\nBACK\n<-" (at 73 100 0) (layer "F.SilkS") (uuid "a0000003") (effects (font (size 0.8 0.8) (thickness 0.12))))
