  ;; ============================================================
  ;; 4 switches + 4x 10k pull-ups + 100nF decoupling + FPC
  ;; All active-low. Pull-ups on this board (not lower PCB).
  ;; ============================================================

  ;; --- POWER NETS (from FPC Pin 1/2) ---
  (global_label "3V3" (shape input) (at 30 40 0) (uuid "00000002-0001-0001-0001-000000000001")
    (effects (font (size 1.27 1.27)))
